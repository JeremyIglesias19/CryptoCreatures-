# === Privy (Auth con Google) ===
NEXT_PUBLIC_PRIVY_APP_ID=tu-privy-app-id
PRIVY_APP_SECRET=tu-privy-secret

# === Base de datos PostgreSQL (Railway) ===
DATABASE_URL=postgresql://user:password@host:5432/cryptocreatures

# === Servidor WebSocket ===
NEXT_PUBLIC_WS_URL=http://localhost:3001
WS_PORT=3001

# === Solana (marketplace P2P) ===
# El marketplace P2P sigue usando Solana. La compra de huevos ahora es via Stripe.
NEXT_PUBLIC_SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# ESCROW_WALLET_SECRET=[1,2,3,...]
# NEXT_PUBLIC_ESCROW_WALLET=

# === Stripe (sistema hibrido de pagos — compra de huevos en EUR) ===
# Obtener en https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Obtener al crear un endpoint en https://dashboard.stripe.com/test/webhooks
# En local, usar `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...

# URL publica de la app (para construir success_url/cancel_url de Stripe)
NEXT_PUBLIC_APP_URL=http://localhost:3000
